{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:genesis:schema:host-consent:v0.1",
  "title": "Genesis Destination Host Consent",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "consent_id",
    "transfer_id",
    "host_id",
    "host_key_epoch_id",
    "instance_id",
    "destination_body_id",
    "resource_scope",
    "granted_at",
    "expires_at",
    "ownership_claim",
    "mobility_veto",
    "consent_digest",
    "signature"
  ],
  "properties": {
    "schema_version": { "const": "genesis.host.consent.v0.1" },
    "consent_id": { "type": "string", "minLength": 16, "maxLength": 128 },
    "transfer_id": { "type": "string", "minLength": 16, "maxLength": 128 },
    "host_id": { "type": "string", "minLength": 16, "maxLength": 128 },
    "host_key_epoch_id": { "type": "string", "minLength": 16, "maxLength": 128 },
    "instance_id": { "type": "string", "minLength": 16, "maxLength": 128 },
    "destination_body_id": { "type": "string", "minLength": 16, "maxLength": 128 },
    "resource_scope": { "const": "destination_body_runtime" },
    "granted_at": { "type": "string", "format": "date-time", "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])-(0[1-9]|[12][0-9]|3[01])T([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]Z$" },
    "expires_at": { "type": "string", "format": "date-time", "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])-(0[1-9]|[12][0-9]|3[01])T([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]Z$" },
    "ownership_claim": { "const": "none" },
    "mobility_veto": { "const": "none" },
    "consent_digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "signature": { "$ref": "urn:genesis:schema:signature-envelope:v0.1" }
  },
  "allOf": [
    {
      "properties": {
        "signature": {
          "type": "object",
          "properties": { "signer_type": { "const": "host" } }
        }
      }
    }
  ]
}
