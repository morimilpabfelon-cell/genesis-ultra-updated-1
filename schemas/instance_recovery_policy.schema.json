{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:genesis:schema:instance-recovery-policy:v0.1",
  "title": "Genesis Instance Recovery Policy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "policy_id",
    "instance_id",
    "policy_epoch",
    "guardian_id",
    "guardian_factor_id",
    "fallback_threshold",
    "fallback_wait_seconds",
    "cancellation_allowed",
    "single_use",
    "factors",
    "created_at",
    "policy_digest",
    "body_commitment",
    "guardian_witness"
  ],
  "properties": {
    "schema_version": { "const": "genesis.instance.recovery.policy.v0.1" },
    "policy_id": { "type": "string", "minLength": 16, "maxLength": 128 },
    "instance_id": { "type": "string", "minLength": 16, "maxLength": 128 },
    "policy_epoch": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
    "guardian_id": { "type": "string", "minLength": 1, "maxLength": 128 },
    "guardian_factor_id": { "type": "string", "minLength": 16, "maxLength": 128 },
    "fallback_threshold": { "type": "integer", "minimum": 2, "maximum": 32 },
    "fallback_wait_seconds": { "type": "integer", "minimum": 1, "maximum": 9007199254740991 },
    "cancellation_allowed": { "const": true },
    "single_use": { "const": true },
    "factors": {
      "type": "array",
      "minItems": 3,
      "maxItems": 32,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["factor_id", "factor_type", "key_epoch_id", "public_key_ref", "allowed_paths"],
        "properties": {
          "factor_id": { "type": "string", "minLength": 16, "maxLength": 128 },
          "factor_type": {
            "type": "string",
            "enum": ["guardian", "instance_recovery_secret", "offline_recovery_kit", "designated_custodian", "hardware_key"]
          },
          "key_epoch_id": { "type": "string", "minLength": 16, "maxLength": 128 },
          "public_key_ref": { "$ref": "#/$defs/sha256" },
          "allowed_paths": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": { "type": "string", "enum": ["guardian_assisted", "policy_fallback"] }
          }
        }
      }
    },
    "created_at": { "$ref": "#/$defs/timestamp" },
    "policy_digest": { "$ref": "#/$defs/sha256" },
    "body_commitment": { "$ref": "urn:genesis:schema:signature-envelope:v0.1" },
    "guardian_witness": { "$ref": "urn:genesis:schema:signature-envelope:v0.1" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])-(0[1-9]|[12][0-9]|3[01])T([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]Z$"
    }
  }
}
