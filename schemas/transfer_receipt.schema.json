{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:genesis:schema:transfer-receipt:v0.1",
  "title": "Genesis Transfer Receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "transfer_id",
    "instance_id",
    "source_body_id",
    "destination_body_id",
    "accepted_package_digest",
    "accepted_checkpoint_hash",
    "accepted_last_event_hash",
    "accepted_last_sequence",
    "accepted_at",
    "continuity_status",
    "continuity_intent_ref",
    "host_consent_ref",
    "destination_possession_ref",
    "guardian_authorization_ref",
    "guardian_authorization_reservation_ref",
    "receipt_digest",
    "signature"
  ],
  "properties": {
    "schema_version": { "const": "genesis.transfer.receipt.v0.1" },
    "transfer_id": { "type": "string", "minLength": 16, "maxLength": 128 },
    "instance_id": { "type": "string", "minLength": 16, "maxLength": 128 },
    "source_body_id": { "type": "string", "minLength": 16, "maxLength": 128 },
    "destination_body_id": { "type": "string", "minLength": 16, "maxLength": 128 },
    "accepted_package_digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "accepted_checkpoint_hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "accepted_last_event_hash": {
      "oneOf": [
        { "const": "GENESIS" },
        { "type": "string", "pattern": "^evsha256:[a-f0-9]{64}$" }
      ]
    },
    "accepted_last_sequence": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
    "accepted_at": { "type": "string", "format": "date-time", "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])-(0[1-9]|[12][0-9]|3[01])T([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]Z$" },
    "continuity_status": { "type": "string", "enum": ["complete", "known_gap", "fork_risk"] },
    "continuity_gap_ref": { "type": ["string", "null"], "maxLength": 256 },
    "continuity_intent_ref": { "type": "string", "minLength": 16, "maxLength": 128 },
    "host_consent_ref": { "type": "string", "minLength": 16, "maxLength": 128 },
    "destination_possession_ref": { "type": "string", "minLength": 16, "maxLength": 128 },
    "guardian_authorization_ref": { "type": "string", "minLength": 16, "maxLength": 128 },
    "guardian_authorization_reservation_ref": { "type": "string", "minLength": 16, "maxLength": 128 },
    "receipt_digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "signature": { "$ref": "urn:genesis:schema:signature-envelope:v0.1" }
  },
  "allOf": [
    {
      "if": {
        "properties": { "continuity_status": { "const": "known_gap" } },
        "required": ["continuity_status"]
      },
      "then": {
        "required": ["continuity_gap_ref"],
        "properties": { "continuity_gap_ref": { "type": "string", "minLength": 1 } }
      }
    },
    {
      "properties": {
        "signature": {
          "type": "object",
          "properties": {
            "signer_type": { "const": "body" },
            "signed_domain": { "const": "genesis.transfer.receipt.signature.v0.1" }
          }
        }
      }
    }
  ]
}
