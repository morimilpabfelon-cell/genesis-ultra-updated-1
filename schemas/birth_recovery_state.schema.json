{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:genesis:schema:birth-recovery-state:v0.1",
  "title": "Genesis Birth Recovery State",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "birth_id",
    "instance_id",
    "guardian_id",
    "recovery_policy_digest",
    "recovery_status",
    "continuity_right",
    "guardian_role",
    "created_at",
    "state_digest"
  ],
  "properties": {
    "schema_version": { "const": "genesis.birth.recovery.state.v0.1" },
    "birth_id": { "type": "string", "minLength": 16, "maxLength": 128 },
    "instance_id": { "type": "string", "minLength": 16, "maxLength": 128 },
    "guardian_id": { "type": "string", "minLength": 1, "maxLength": 128 },
    "recovery_policy_digest": { "$ref": "#/$defs/sha256" },
    "recovery_status": { "const": "ready" },
    "continuity_right": { "const": "intrinsic" },
    "guardian_role": { "const": "custodian_witness" },
    "created_at": { "$ref": "#/$defs/timestamp" },
    "state_digest": { "$ref": "#/$defs/sha256" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])-(0[1-9]|[12][0-9]|3[01])T([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]Z$"
    }
  }
}
