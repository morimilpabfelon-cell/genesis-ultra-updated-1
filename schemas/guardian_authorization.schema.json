{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:genesis:schema:guardian-authorization:v0.1",
  "title": "Genesis Guardian Authorization",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "authorization_id",
    "guardian_id",
    "instance_id",
    "subject_type",
    "subject_id",
    "allowed_actions",
    "scope_digest",
    "artifact_digests",
    "issued_at",
    "expires_at",
    "use_limit",
    "used_count",
    "revoked",
    "authorization_digest"
  ],
  "properties": {
    "schema_version": {
      "const": "genesis.guardian.authorization.v0.1"
    },
    "authorization_id": {
      "type": "string",
      "minLength": 16,
      "maxLength": 128
    },
    "guardian_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "instance_id": {
      "type": "string",
      "minLength": 16,
      "maxLength": 128
    },
    "subject_type": {
      "type": "string",
      "enum": [
        "birth",
        "body",
        "transfer",
        "recovery",
        "backup",
        "export",
        "growth",
        "migration",
        "engine",
        "tool",
        "other"
      ]
    },
    "subject_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "allowed_actions": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 128
      }
    },
    "scope_digest": {
      "$ref": "#/$defs/sha256"
    },
    "artifact_digests": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/sha256"
      }
    },
    "issued_at": {
      "type": "string",
      "format": "date-time"
    },
    "expires_at": {
      "type": "string",
      "format": "date-time"
    },
    "use_limit": {
      "type": "integer",
      "minimum": 1
    },
    "used_count": {
      "type": "integer",
      "minimum": 0
    },
    "revoked": {
      "type": "boolean"
    },
    "authorization_digest": {
      "$ref": "#/$defs/sha256"
    },
    "signature": {
      "type": [
        "object",
        "null"
      ]
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    }
  }
}
