{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:genesis:schema:guardian-mobility-authorization:v0.2",
  "title": "Genesis Guardian Mobility Authorization",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "hash_profile",
    "authorization_id",
    "instance_id",
    "guardian_id",
    "guardian_key_epoch_id",
    "authority_epoch",
    "mode",
    "scope",
    "transfer_id",
    "source_body_id",
    "destination_body_id",
    "valid_from",
    "expires_at",
    "issued_at",
    "reservation_ttl_seconds",
    "ownership_conferred",
    "identity_mutation_allowed",
    "memory_mutation_allowed",
    "authorization_digest",
    "signature"
  ],
  "properties": {
    "schema_version": { "const": "genesis.guardian.mobility.authorization.v0.2" },
    "hash_profile": { "const": "genesis.hash.fields.v0.1" },
    "authorization_id": { "type": "string", "minLength": 16, "maxLength": 128 },
    "instance_id": { "type": "string", "minLength": 16, "maxLength": 128 },
    "guardian_id": { "type": "string", "minLength": 1, "maxLength": 128 },
    "guardian_key_epoch_id": { "type": "string", "minLength": 16, "maxLength": 128 },
    "authority_epoch": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
    "mode": { "type": "string", "enum": ["one_time", "standing"] },
    "scope": { "type": "string", "enum": ["exact_transfer", "any_registered_body_with_host_consent"] },
    "transfer_id": { "type": ["string", "null"], "minLength": 16, "maxLength": 128 },
    "source_body_id": { "type": ["string", "null"], "minLength": 16, "maxLength": 128 },
    "destination_body_id": { "type": ["string", "null"], "minLength": 16, "maxLength": 128 },
    "valid_from": { "$ref": "#/$defs/timestamp" },
    "expires_at": { "$ref": "#/$defs/timestamp" },
    "issued_at": { "$ref": "#/$defs/timestamp" },
    "reservation_ttl_seconds": { "type": "integer", "minimum": 60, "maximum": 86400 },
    "ownership_conferred": { "const": false },
    "identity_mutation_allowed": { "const": false },
    "memory_mutation_allowed": { "const": false },
    "authorization_digest": { "$ref": "#/$defs/sha256" },
    "signature": { "$ref": "urn:genesis:schema:signature-envelope:v0.1" }
  },
  "allOf": [
    {
      "if": { "properties": { "mode": { "const": "one_time" } }, "required": ["mode"] },
      "then": {
        "properties": {
          "scope": { "const": "exact_transfer" },
          "transfer_id": { "type": "string", "minLength": 16, "maxLength": 128 },
          "source_body_id": { "type": "string", "minLength": 16, "maxLength": 128 },
          "destination_body_id": { "type": "string", "minLength": 16, "maxLength": 128 }
        }
      }
    },
    {
      "if": { "properties": { "mode": { "const": "standing" } }, "required": ["mode"] },
      "then": {
        "properties": {
          "scope": { "const": "any_registered_body_with_host_consent" },
          "transfer_id": { "type": "null" },
          "source_body_id": { "type": "null" },
          "destination_body_id": { "type": "null" }
        }
      }
    },
    {
      "properties": {
        "signature": {
          "type": "object",
          "properties": {
            "signer_type": { "const": "guardian" },
            "signed_domain": { "const": "genesis.guardian.mobility.authorization.signature.v0.2" }
          }
        }
      }
    }
  ],
  "$defs": {
    "sha256": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])-(0[1-9]|[12][0-9]|3[01])T([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]Z$"
    }
  }
}
