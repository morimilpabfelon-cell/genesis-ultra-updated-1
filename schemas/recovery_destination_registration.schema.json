{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:genesis:schema:recovery-destination-registration:v0.1",
  "title": "Genesis Recovery Destination Registration",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "registration_id",
    "recovery_id",
    "recovery_authorization_ref",
    "recovery_authorization_digest",
    "instance_id",
    "body_id",
    "platform_profile",
    "public_key_fingerprint",
    "registered_at",
    "registration_digest",
    "signature"
  ],
  "properties": {
    "schema_version": { "const": "genesis.recovery.destination.registration.v0.1" },
    "registration_id": { "type": "string", "minLength": 16, "maxLength": 128 },
    "recovery_id": { "type": "string", "minLength": 16, "maxLength": 128 },
    "recovery_authorization_ref": { "type": "string", "minLength": 16, "maxLength": 128 },
    "recovery_authorization_digest": { "$ref": "#/$defs/sha256" },
    "instance_id": { "type": "string", "minLength": 16, "maxLength": 128 },
    "body_id": { "type": "string", "minLength": 16, "maxLength": 128 },
    "platform_profile": { "type": "string", "minLength": 1, "maxLength": 128 },
    "public_key_fingerprint": { "$ref": "#/$defs/sha256" },
    "registered_at": { "$ref": "#/$defs/timestamp" },
    "registration_digest": { "$ref": "#/$defs/sha256" },
    "signature": { "$ref": "urn:genesis:schema:signature-envelope:v0.1" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])-(0[1-9]|[12][0-9]|3[01])T([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]Z$"
    }
  }
}
