{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:genesis:schema:structured-versioned-memory-projection:v0.1",
  "title": "Genesis Structured Versioned Memory Projection",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "hash_profile",
    "projection_profile",
    "projection_id",
    "instance_id",
    "source_first_sequence",
    "source_last_sequence",
    "source_event_count",
    "source_last_event_hash",
    "assertion_count",
    "slot_count",
    "active_slot_count",
    "retracted_slot_count",
    "slots",
    "projection_digest"
  ],
  "properties": {
    "schema_version": { "const": "genesis.memory.structured_versioned.projection.v0.1" },
    "hash_profile": { "const": "genesis.hash.fields.v0.1" },
    "projection_profile": { "const": "genesis.memory.structured_versioned.algorithm.v0.1" },
    "projection_id": { "$ref": "#/$defs/svp_digest" },
    "instance_id": { "type": "string", "minLength": 16, "maxLength": 128 },
    "source_first_sequence": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
    "source_last_sequence": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
    "source_event_count": { "type": "integer", "minimum": 1, "maximum": 9007199254740991 },
    "source_last_event_hash": { "$ref": "#/$defs/event_hash" },
    "assertion_count": { "type": "integer", "minimum": 1, "maximum": 9007199254740991 },
    "slot_count": { "type": "integer", "minimum": 1, "maximum": 9007199254740991 },
    "active_slot_count": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
    "retracted_slot_count": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
    "slots": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/slot" }
    },
    "projection_digest": { "$ref": "#/$defs/svp_digest" }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "event_hash": {
      "type": "string",
      "pattern": "^evsha256:[0-9a-f]{64}$"
    },
    "assertion_digest": {
      "type": "string",
      "pattern": "^svasha256:[0-9a-f]{64}$"
    },
    "history_digest": {
      "type": "string",
      "pattern": "^svhsha256:[0-9a-f]{64}$"
    },
    "slot_digest": {
      "type": "string",
      "pattern": "^slotsha256:[0-9a-f]{64}$"
    },
    "svp_digest": {
      "type": "string",
      "pattern": "^svpsha256:[0-9a-f]{64}$"
    },
    "canonical_timestamp_or_null": {
      "oneOf": [
        {
          "type": "string",
          "format": "date-time",
          "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])-(0[1-9]|[12][0-9]|3[01])T([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]Z$"
        },
        { "type": "null" }
      ]
    },
    "current_item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value", "value_digest", "assertion_ref"],
      "properties": {
        "value": { "type": "string", "minLength": 1, "maxLength": 4096 },
        "value_digest": { "$ref": "#/$defs/sha256" },
        "assertion_ref": { "type": "string", "minLength": 3, "maxLength": 128 }
      }
    },
    "history_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "assertion_id",
        "assertion_digest",
        "source_event_ref",
        "source_event_hash",
        "source_sequence",
        "source_ordinal",
        "operation",
        "value",
        "value_digest",
        "polarity",
        "valid_from",
        "valid_to",
        "status_after",
        "history_digest"
      ],
      "properties": {
        "assertion_id": { "type": "string", "minLength": 3, "maxLength": 128 },
        "assertion_digest": { "$ref": "#/$defs/assertion_digest" },
        "source_event_ref": { "type": "string", "minLength": 16, "maxLength": 128 },
        "source_event_hash": { "$ref": "#/$defs/event_hash" },
        "source_sequence": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
        "source_ordinal": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
        "operation": { "enum": ["sets", "updates", "extends", "retracts"] },
        "value": { "type": "string", "minLength": 1, "maxLength": 4096 },
        "value_digest": { "$ref": "#/$defs/sha256" },
        "polarity": { "enum": ["positive", "negative", "neutral"] },
        "valid_from": { "$ref": "#/$defs/canonical_timestamp_or_null" },
        "valid_to": { "$ref": "#/$defs/canonical_timestamp_or_null" },
        "status_after": { "enum": ["active", "retracted"] },
        "history_digest": { "$ref": "#/$defs/history_digest" }
      }
    },
    "slot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "slot_id",
        "version_key",
        "kind",
        "entity",
        "slot",
        "privacy",
        "scope",
        "status",
        "current_items",
        "history",
        "slot_digest"
      ],
      "properties": {
        "slot_id": { "$ref": "#/$defs/slot_digest" },
        "version_key": { "type": "string", "minLength": 3, "maxLength": 512 },
        "kind": { "enum": ["fact", "preference", "event", "profile", "relationship", "goal", "other"] },
        "entity": { "type": "string", "minLength": 1, "maxLength": 255 },
        "slot": { "type": "string", "minLength": 1, "maxLength": 255 },
        "privacy": { "enum": ["private_local", "guardian_shared", "export_approved"] },
        "scope": { "type": "string", "minLength": 1, "maxLength": 255 },
        "status": { "enum": ["active", "retracted"] },
        "current_items": {
          "type": "array",
          "items": { "$ref": "#/$defs/current_item" }
        },
        "history": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/history_item" }
        },
        "slot_digest": { "$ref": "#/$defs/slot_digest" }
      }
    }
  }
}
