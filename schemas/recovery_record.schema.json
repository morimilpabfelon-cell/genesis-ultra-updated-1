{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:genesis:schema:recovery-record:v0.1",
  "title": "Genesis Recovery Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "recovery_id",
    "instance_id",
    "source_backup_id",
    "source_backup_commit_digest",
    "new_body_id",
    "previous_body_id",
    "restored_checkpoint_hash",
    "restored_last_event_hash",
    "restored_last_sequence",
    "last_known_sequence",
    "continuity_status",
    "continuity_gap_ref",
    "recovery_authorization_ref",
    "recovery_authorization_digest",
    "previous_body_revocation_ref",
    "destination_registration_ref",
    "destination_possession_ref",
    "performed_at",
    "recovery_digest",
    "signature"
  ],
  "properties": {
    "schema_version": { "const": "genesis.recovery.record.v0.1" },
    "recovery_id": { "type": "string", "minLength": 16, "maxLength": 128 },
    "instance_id": { "type": "string", "minLength": 16, "maxLength": 128 },
    "source_backup_id": { "type": "string", "minLength": 16, "maxLength": 128 },
    "source_backup_commit_digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "new_body_id": { "type": "string", "minLength": 16, "maxLength": 128 },
    "previous_body_id": { "type": ["string", "null"], "maxLength": 128 },
    "restored_checkpoint_hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "restored_last_event_hash": {
      "oneOf": [
        { "const": "GENESIS" },
        { "type": "string", "pattern": "^evsha256:[a-f0-9]{64}$" }
      ]
    },
    "restored_last_sequence": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
    "last_known_sequence": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
    "continuity_status": {
      "type": "string",
      "enum": ["complete", "known_gap", "fork_risk"]
    },
    "continuity_gap_ref": { "type": ["string", "null"], "maxLength": 256 },
    "recovery_authorization_ref": { "type": "string", "minLength": 1, "maxLength": 256 },
    "recovery_authorization_digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "previous_body_revocation_ref": { "type": "string", "minLength": 1, "maxLength": 256 },
    "destination_registration_ref": { "type": "string", "minLength": 1, "maxLength": 256 },
    "destination_possession_ref": { "type": "string", "minLength": 1, "maxLength": 256 },
    "performed_at": { "type": "string", "format": "date-time", "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])-(0[1-9]|[12][0-9]|3[01])T([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]Z$" },
    "recovery_digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "signature": { "$ref": "urn:genesis:schema:signature-envelope:v0.1" }
  },
  "allOf": [
    {
      "if": {
        "properties": { "continuity_status": { "enum": ["known_gap", "fork_risk"] } },
        "required": ["continuity_status"]
      },
      "then": {
        "required": ["continuity_gap_ref"],
        "properties": { "continuity_gap_ref": { "type": "string", "minLength": 1 } }
      }
    },
    {
      "if": {
        "properties": { "continuity_status": { "const": "complete" } },
        "required": ["continuity_status"]
      },
      "then": {
        "properties": { "continuity_gap_ref": { "type": "null" } }
      }
    },
    {
      "properties": {
        "signature": {
          "type": "object",
          "properties": { "signer_type": { "const": "body" } }
        }
      }
    }
  ]
}
