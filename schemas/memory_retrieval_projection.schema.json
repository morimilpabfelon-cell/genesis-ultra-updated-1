{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://genesis.local/schemas/memory_retrieval_projection.schema.json",
  "title": "Genesis deterministic memory retrieval projection",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "hash_profile",
    "projection_id",
    "instance_id",
    "projection_profile",
    "coverage_status",
    "source_first_sequence",
    "source_last_sequence",
    "source_event_count",
    "source_last_event_hash",
    "record_count",
    "frames",
    "lexicon",
    "checkpoints",
    "query_results",
    "projection_digest"
  ],
  "properties": {
    "schema_version": { "const": "genesis.memory.retrieval.projection.v0.1" },
    "hash_profile": { "const": "genesis.hash.fields.v0.1" },
    "projection_id": { "type": "string", "pattern": "^rpsha256:[a-f0-9]{64}$" },
    "instance_id": { "type": "string", "minLength": 1, "maxLength": 128 },
    "projection_profile": { "const": "genesis.memory.retrieval.algorithm.v0.1" },
    "coverage_status": { "const": "complete" },
    "source_first_sequence": { "$ref": "#/$defs/portableInteger" },
    "source_last_sequence": { "$ref": "#/$defs/portableInteger" },
    "source_event_count": { "$ref": "#/$defs/positivePortableInteger" },
    "source_last_event_hash": { "type": "string", "pattern": "^evsha256:[a-f0-9]{64}$" },
    "record_count": { "$ref": "#/$defs/positivePortableInteger" },
    "frames": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1000000,
      "items": { "$ref": "#/$defs/retrievalFrame" }
    },
    "lexicon": {
      "type": "array",
      "maxItems": 10000000,
      "items": { "$ref": "#/$defs/lexiconEntry" }
    },
    "checkpoints": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1000000,
      "items": { "$ref": "#/$defs/checkpoint" }
    },
    "query_results": {
      "type": "array",
      "minItems": 1,
      "maxItems": 10000,
      "items": { "$ref": "#/$defs/queryResultSet" }
    },
    "projection_digest": { "$ref": "#/$defs/sha256" }
  },
  "$defs": {
    "portableInteger": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "positivePortableInteger": {
      "type": "integer",
      "minimum": 1,
      "maximum": 9007199254740991
    },
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "canonicalTimestamp": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])-(0[1-9]|[12][0-9]|3[01])T([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]Z$"
    },
    "termFrequency": {
      "type": "object",
      "additionalProperties": false,
      "required": ["term", "frequency"],
      "properties": {
        "term": { "type": "string", "pattern": "^[a-z0-9]+$", "minLength": 1, "maxLength": 128 },
        "frequency": { "$ref": "#/$defs/positivePortableInteger" }
      }
    },
    "retrievalFrame": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "frame_id",
        "event_id",
        "sequence",
        "observed_at",
        "content_digest",
        "content_type",
        "token_count",
        "terms"
      ],
      "properties": {
        "frame_id": { "type": "string", "pattern": "^rfsha256:[a-f0-9]{64}$" },
        "event_id": { "type": "string", "minLength": 1, "maxLength": 128 },
        "sequence": { "$ref": "#/$defs/portableInteger" },
        "observed_at": { "$ref": "#/$defs/canonicalTimestamp" },
        "content_digest": { "$ref": "#/$defs/sha256" },
        "content_type": { "type": "string", "minLength": 1, "maxLength": 256 },
        "token_count": { "$ref": "#/$defs/positivePortableInteger" },
        "terms": {
          "type": "array",
          "minItems": 1,
          "maxItems": 100000,
          "items": { "$ref": "#/$defs/termFrequency" }
        }
      }
    },
    "lexiconEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["term", "document_frequency", "event_refs"],
      "properties": {
        "term": { "type": "string", "pattern": "^[a-z0-9]+$", "minLength": 1, "maxLength": 128 },
        "document_frequency": { "$ref": "#/$defs/positivePortableInteger" },
        "event_refs": {
          "type": "array",
          "minItems": 1,
          "maxItems": 1000000,
          "items": { "type": "string", "minLength": 1, "maxLength": 128 }
        }
      }
    },
    "checkpoint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sequence", "frame_count", "frames_digest"],
      "properties": {
        "sequence": { "$ref": "#/$defs/portableInteger" },
        "frame_count": { "$ref": "#/$defs/positivePortableInteger" },
        "frames_digest": { "$ref": "#/$defs/sha256" }
      }
    },
    "queryResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rank",
        "event_id",
        "frame_id",
        "sequence",
        "score",
        "lexical_score",
        "graph_score",
        "temporal_score",
        "matched_terms",
        "reason_codes"
      ],
      "properties": {
        "rank": { "$ref": "#/$defs/positivePortableInteger" },
        "event_id": { "type": "string", "minLength": 1, "maxLength": 128 },
        "frame_id": { "type": "string", "pattern": "^rfsha256:[a-f0-9]{64}$" },
        "sequence": { "$ref": "#/$defs/portableInteger" },
        "score": { "$ref": "#/$defs/portableInteger" },
        "lexical_score": { "$ref": "#/$defs/portableInteger" },
        "graph_score": { "$ref": "#/$defs/portableInteger" },
        "temporal_score": { "$ref": "#/$defs/portableInteger" },
        "matched_terms": {
          "type": "array",
          "maxItems": 1000,
          "items": { "type": "string", "pattern": "^[a-z0-9]+$", "maxLength": 128 }
        },
        "reason_codes": {
          "type": "array",
          "minItems": 1,
          "maxItems": 3,
          "items": { "enum": ["lexical_match", "graph_anchor", "graph_neighbor"] }
        }
      }
    },
    "queryResultSet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "query_id",
        "query_digest",
        "normalized_terms",
        "as_of_sequence",
        "top_k",
        "candidate_count",
        "results",
        "result_digest"
      ],
      "properties": {
        "query_id": { "type": "string", "pattern": "^[A-Za-z0-9._:-]+$", "minLength": 1, "maxLength": 128 },
        "query_digest": { "type": "string", "pattern": "^rqsha256:[a-f0-9]{64}$" },
        "normalized_terms": {
          "type": "array",
          "maxItems": 1000,
          "items": { "type": "string", "pattern": "^[a-z0-9]+$", "maxLength": 128 }
        },
        "as_of_sequence": { "$ref": "#/$defs/portableInteger" },
        "top_k": {
          "type": "integer",
          "minimum": 1,
          "maximum": 20
        },
        "candidate_count": { "$ref": "#/$defs/positivePortableInteger" },
        "results": {
          "type": "array",
          "maxItems": 20,
          "items": { "$ref": "#/$defs/queryResult" }
        },
        "result_digest": { "$ref": "#/$defs/sha256" }
      }
    }
  }
}
