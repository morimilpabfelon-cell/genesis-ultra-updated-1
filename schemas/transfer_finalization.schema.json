{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:genesis:schema:transfer-finalization:v0.1",
  "title": "Genesis Transfer Finalization",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "transfer_id",
    "instance_id",
    "source_body_id",
    "destination_body_id",
    "receipt_digest",
    "source_final_status",
    "destination_final_status",
    "finalized_at",
    "continuity_intent_ref",
    "host_consent_ref",
    "destination_possession_ref",
    "guardian_authorization_ref",
    "guardian_authorization_reservation_ref",
    "finalization_digest",
    "source_acknowledgement",
    "destination_acknowledgement"
  ],
  "properties": {
    "schema_version": { "const": "genesis.transfer.finalization.v0.1" },
    "transfer_id": { "type": "string", "minLength": 16, "maxLength": 128 },
    "instance_id": { "type": "string", "minLength": 16, "maxLength": 128 },
    "source_body_id": { "type": "string", "minLength": 16, "maxLength": 128 },
    "destination_body_id": { "type": "string", "minLength": 16, "maxLength": 128 },
    "receipt_digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "source_final_status": { "type": "string", "enum": ["read_only", "revoked", "lost"] },
    "destination_final_status": { "const": "active_writer" },
    "finalized_at": { "type": "string", "format": "date-time", "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])-(0[1-9]|[12][0-9]|3[01])T([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]Z$" },
    "continuity_intent_ref": { "type": "string", "minLength": 16, "maxLength": 128 },
    "host_consent_ref": { "type": "string", "minLength": 16, "maxLength": 128 },
    "destination_possession_ref": { "type": "string", "minLength": 16, "maxLength": 128 },
    "guardian_authorization_ref": { "type": "string", "minLength": 16, "maxLength": 128 },
    "guardian_authorization_reservation_ref": { "type": "string", "minLength": 16, "maxLength": 128 },
    "finalization_digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "source_acknowledgement": { "$ref": "urn:genesis:schema:signature-envelope:v0.1" },
    "destination_acknowledgement": { "$ref": "urn:genesis:schema:signature-envelope:v0.1" }
  },
  "allOf": [
    {
      "properties": {
        "source_acknowledgement": {
          "type": "object",
          "properties": {
            "signer_type": { "const": "body" },
            "signed_domain": { "const": "genesis.transfer.finalization.signature.v0.1" }
          }
        },
        "destination_acknowledgement": {
          "type": "object",
          "properties": {
            "signer_type": { "const": "body" },
            "signed_domain": { "const": "genesis.transfer.finalization.signature.v0.1" }
          }
        }
      }
    }
  ]
}
