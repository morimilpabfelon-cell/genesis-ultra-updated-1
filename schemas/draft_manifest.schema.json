{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:genesis:schema:draft-manifest:v0.1",
  "title": "Genesis Draft Integrity Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "protocol_version",
    "root_hash_profile",
    "file_digest_algorithm",
    "inventory_path",
    "manifest_path",
    "self_excluded",
    "file_count",
    "files",
    "root_digest"
  ],
  "properties": {
    "schema_version": {
      "const": "genesis.draft.manifest.v0.1"
    },
    "protocol_version": {
      "const": "genesis.protocol.v0.1"
    },
    "root_hash_profile": {
      "const": "genesis.hash.fields.v0.1"
    },
    "file_digest_algorithm": {
      "const": "sha256"
    },
    "inventory_path": {
      "const": "conformance/required_artifacts.json"
    },
    "manifest_path": {
      "const": "conformance/draft_manifest.json"
    },
    "self_excluded": {
      "const": true
    },
    "file_count": {
      "type": "integer",
      "minimum": 1,
      "maximum": 9007199254740991
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/file_record"
      }
    },
    "root_digest": {
      "$ref": "#/$defs/sha256"
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "safe_path": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024,
      "pattern": "^(?!/)(?!.*\\\\)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*(?:^|/)\\.(?:/|$)).+$"
    },
    "file_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "size_bytes",
        "digest"
      ],
      "properties": {
        "path": {
          "$ref": "#/$defs/safe_path"
        },
        "size_bytes": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "digest": {
          "$ref": "#/$defs/sha256"
        }
      }
    }
  }
}
