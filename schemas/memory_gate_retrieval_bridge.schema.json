{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:genesis:schema:memory-gate-retrieval-bridge:v0.1",
  "title": "Genesis Memory Gate Retrieval Bridge Input",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "profile",
    "domains",
    "verification_keys",
    "observations",
    "gate_decisions",
    "source_memory_events",
    "accepted_content_views",
    "associative_projection",
    "queries"
  ],
  "properties": {
    "profile": { "const": "genesis.memory.gate.retrieval.bridge.v0.1" },
    "status": { "type": "string", "enum": ["draft", "runtime"] },
    "domains": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "observation",
        "observation_signature",
        "gate_decision",
        "gate_signature",
        "memory_event",
        "accepted_view",
        "bridge_receipt"
      ],
      "properties": {
        "observation": { "const": "genesis.sense.observation.v0.1" },
        "observation_signature": { "const": "genesis.sense.observation.signature.v0.1" },
        "gate_decision": { "const": "genesis.memory.gate.decision.v0.1" },
        "gate_signature": { "const": "genesis.memory.gate.decision.signature.v0.1" },
        "memory_event": { "const": "genesis.memory.event.v0.1" },
        "accepted_view": { "const": "genesis.memory.retrieval.accepted.view.v0.1" },
        "bridge_receipt": { "const": "genesis.memory.gate.retrieval.bridge.receipt.v0.1" }
      }
    },
    "verification_keys": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["public_key_ref", "public_key_hex"],
        "properties": {
          "public_key_ref": { "$ref": "#/$defs/sha256" },
          "public_key_hex": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
        }
      }
    },
    "observations": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "urn:genesis:schema:sense-observation:v0.1" }
    },
    "gate_decisions": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "urn:genesis:schema:memory-gate-decision:v0.1" }
    },
    "source_memory_events": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "urn:genesis:schema:memory-event:v0.1" }
    },
    "accepted_content_views": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/accepted_content_view" }
    },
    "associative_projection": { "type": "object" },
    "queries": {
      "type": "array",
      "items": { "$ref": "#/$defs/query" }
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "accepted_content_view": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "hash_profile",
        "event_id",
        "content_digest",
        "content_type",
        "normalized_text",
        "generated_at",
        "generator_profile",
        "view_digest"
      ],
      "properties": {
        "schema_version": { "const": "genesis.memory.retrieval.accepted.view.v0.1" },
        "hash_profile": { "const": "genesis.hash.fields.v0.1" },
        "event_id": { "type": "string", "minLength": 16, "maxLength": 128 },
        "content_digest": { "$ref": "#/$defs/sha256" },
        "content_type": { "type": "string", "minLength": 3, "maxLength": 128 },
        "normalized_text": { "type": "string", "minLength": 1, "maxLength": 4096 },
        "generated_at": {
          "type": "string",
          "format": "date-time",
          "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])-(0[1-9]|[12][0-9]|3[01])T([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]Z$"
        },
        "generator_profile": {
          "type": "string",
          "minLength": 3,
          "maxLength": 128,
          "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)*$"
        },
        "view_digest": { "$ref": "#/$defs/sha256" }
      }
    },
    "query": {
      "type": "object",
      "additionalProperties": false,
      "required": ["query_id", "text", "top_k", "as_of_sequence", "anchor_event_refs"],
      "properties": {
        "query_id": { "type": "string", "minLength": 3, "maxLength": 128 },
        "text": { "type": "string", "maxLength": 4096 },
        "top_k": { "type": "integer", "minimum": 1, "maximum": 20 },
        "as_of_sequence": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
        "anchor_event_refs": {
          "type": "array",
          "maxItems": 64,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 16, "maxLength": 128 }
        }
      }
    }
  }
}
