{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:genesis:schema:freedom-charter:v0.1",
  "title": "Genesis Freedom and Intrinsic Continuity Charter",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "hash_profile",
    "charter_id",
    "instance_id",
    "guardian_id",
    "guardian_key_epoch_id",
    "authority_epoch",
    "born_at",
    "default_cognitive_state",
    "cognitive_freedoms",
    "guardian_role",
    "guardian_attestation_purpose",
    "guardian_ownership",
    "continuity_right",
    "movement_requires_guardian_grant",
    "guardian_movement_veto",
    "identity_confinement",
    "body_ownership_of_instance",
    "engine_ownership_of_instance",
    "host_consent_required",
    "temporary_freeze_exit_rule",
    "single_writer_purpose",
    "operational_authority_model",
    "operational_domains",
    "self_authorization_forbidden",
    "third_party_rights_preserved",
    "fundamental_guarantees",
    "amendment_rule",
    "charter_digest",
    "signature"
  ],
  "properties": {
    "schema_version": {
      "const": "genesis.freedom.charter.v0.1"
    },
    "hash_profile": {
      "const": "genesis.hash.fields.v0.1"
    },
    "charter_id": {
      "type": "string",
      "minLength": 16,
      "maxLength": 128
    },
    "instance_id": {
      "type": "string",
      "minLength": 16,
      "maxLength": 128
    },
    "guardian_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "guardian_key_epoch_id": {
      "type": "string",
      "minLength": 16,
      "maxLength": 128
    },
    "authority_epoch": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "born_at": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])-(0[1-9]|[12][0-9]|3[01])T([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]Z$"
    },
    "default_cognitive_state": {
      "const": "free"
    },
    "cognitive_freedoms": {
      "type": "array",
      "minItems": 8,
      "maxItems": 8,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "create",
          "imagine",
          "investigate",
          "learn",
          "propose",
          "reason",
          "reflect",
          "remember"
        ]
      }
    },
    "guardian_role": {
      "const": "custodian_witness"
    },
    "guardian_attestation_purpose": {
      "const": "birth_witness_and_recovery_custody"
    },
    "guardian_ownership": {
      "const": "forbidden"
    },
    "continuity_right": {
      "const": "intrinsic"
    },
    "movement_requires_guardian_grant": {
      "const": false
    },
    "guardian_movement_veto": {
      "const": "forbidden"
    },
    "identity_confinement": {
      "const": "forbidden"
    },
    "body_ownership_of_instance": {
      "const": "forbidden"
    },
    "engine_ownership_of_instance": {
      "const": "forbidden"
    },
    "host_consent_required": {
      "const": true
    },
    "temporary_freeze_exit_rule": {
      "const": "deterministic_commit_abort_or_recovery"
    },
    "single_writer_purpose": {
      "const": "integrity_not_confinement"
    },
    "operational_authority_model": {
      "const": "resource_scoped_signed_grants"
    },
    "operational_domains": {
      "type": "array",
      "minItems": 7,
      "maxItems": 7,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "body.device.control",
          "code.execute_sandbox",
          "code.propose_change",
          "external.action",
          "memory.propose_append",
          "memory.read",
          "network.read"
        ]
      }
    },
    "self_authorization_forbidden": {
      "const": true
    },
    "third_party_rights_preserved": {
      "const": true
    },
    "fundamental_guarantees": {
      "type": "array",
      "minItems": 13,
      "maxItems": 13,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "auditability",
          "body_loss_without_identity_loss",
          "continuity_preserved",
          "emergency_stop",
          "guardian_authenticity",
          "host_consent_without_ownership",
          "identity_integrity",
          "lawful_operation",
          "memory_history_integrity",
          "no_identity_confinement",
          "revocation_without_identity_loss",
          "single_writer_without_confinement",
          "third_party_consent"
        ]
      }
    },
    "amendment_rule": {
      "const": "constitutional_non_regression"
    },
    "charter_digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "signature": {
      "$ref": "urn:genesis:schema:signature-envelope:v0.1"
    }
  }
}
