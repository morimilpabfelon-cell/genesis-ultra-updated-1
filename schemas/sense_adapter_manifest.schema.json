{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:genesis:schema:sense-adapter-manifest:v0.1",
  "title": "Genesis Sense Adapter Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "adapter_id",
    "adapter_version",
    "platform_profile",
    "sense",
    "source_kinds",
    "verification_state",
    "permission_model",
    "capabilities",
    "boundary"
  ],
  "properties": {
    "schema_version": { "const": "genesis.sense.adapter.manifest.v0.1" },
    "adapter_id": {
      "type": "string",
      "minLength": 3,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "adapter_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?$"
    },
    "platform_profile": { "type": "string", "minLength": 3, "maxLength": 128 },
    "sense": {
      "type": "string",
      "enum": ["vision", "proprioception", "interoception"]
    },
    "source_kinds": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": ["local_sensor", "user_input", "runtime_state", "network_evidence", "clock"]
      }
    },
    "verification_state": {
      "type": "string",
      "enum": ["declaration_only", "simulated", "platform_verified"]
    },
    "permission_model": {
      "type": "string",
      "enum": ["os_runtime", "local_runtime", "not_required"]
    },
    "capabilities": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "genesis.sense.capture.digest_only.v0.1",
          "genesis.sense.capture.fail_closed.v0.1",
          "genesis.sense.capture.permission_aware.v0.1",
          "genesis.sense.capture.provenance.v0.1"
        ]
      }
    },
    "boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "emits_raw_payload",
        "exports_platform_handles",
        "writes_memory",
        "executes_actions",
        "mutates_identity"
      ],
      "properties": {
        "emits_raw_payload": { "const": false },
        "exports_platform_handles": { "const": false },
        "writes_memory": { "const": false },
        "executes_actions": { "const": false },
        "mutates_identity": { "const": false }
      }
    }
  }
}
