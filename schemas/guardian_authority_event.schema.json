{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:genesis:schema:guardian-authority-event:v0.1",
  "title": "Genesis Guardian Authority Ledger Event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "ledger_id",
    "event_id",
    "sequence",
    "previous_event_hash",
    "guardian_id",
    "instance_id",
    "authority_epoch",
    "event_type",
    "authorization_ref",
    "body_id",
    "transfer_id",
    "subject_digest",
    "recorded_at",
    "event_hash",
    "signature"
  ],
  "properties": {
    "schema_version": { "const": "genesis.guardian.authority.event.v0.1" },
    "ledger_id": { "type": "string", "minLength": 16, "maxLength": 128 },
    "event_id": { "type": "string", "minLength": 16, "maxLength": 128 },
    "sequence": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
    "previous_event_hash": {
      "anyOf": [
        { "const": "GENESIS" },
        { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
      ]
    },
    "guardian_id": { "type": "string", "minLength": 1, "maxLength": 128 },
    "instance_id": { "type": "string", "minLength": 16, "maxLength": 128 },
    "authority_epoch": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
    "event_type": {
      "type": "string",
      "enum": [
        "device.registered",
        "device.revoked",
        "authorization.granted",
        "authorization.consumed",
        "authorization.revoked",
        "authority.epoch.rotated"
      ]
    },
    "authorization_ref": { "type": ["string", "null"], "minLength": 16, "maxLength": 128 },
    "body_id": { "type": ["string", "null"], "minLength": 16, "maxLength": 128 },
    "transfer_id": { "type": ["string", "null"], "minLength": 16, "maxLength": 128 },
    "subject_digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "recorded_at": { "type": "string", "format": "date-time", "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])-(0[1-9]|[12][0-9]|3[01])T([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]Z$" },
    "event_hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "signature": { "$ref": "urn:genesis:schema:signature-envelope:v0.1" }
  },
  "allOf": [
    {
      "if": {
        "properties": { "event_type": { "enum": ["device.registered", "device.revoked"] } },
        "required": ["event_type"]
      },
      "then": {
        "properties": {
          "authorization_ref": { "type": "null" },
          "body_id": { "type": "string" },
          "transfer_id": { "type": "null" },
          "signature": { "type": "object", "properties": { "signer_type": { "const": "guardian" } } }
        }
      }
    },
    {
      "if": {
        "properties": { "event_type": { "enum": ["authorization.granted", "authorization.revoked"] } },
        "required": ["event_type"]
      },
      "then": {
        "properties": {
          "authorization_ref": { "type": "string" },
          "body_id": { "type": "null" },
          "transfer_id": { "type": "null" },
          "signature": { "type": "object", "properties": { "signer_type": { "const": "guardian" } } }
        }
      }
    },
    {
      "if": {
        "properties": { "event_type": { "const": "authorization.consumed" } },
        "required": ["event_type"]
      },
      "then": {
        "properties": {
          "authorization_ref": { "type": "string" },
          "body_id": { "type": "string" },
          "transfer_id": { "type": "string" },
          "signature": { "type": "object", "properties": { "signer_type": { "const": "body" } } }
        }
      }
    },
    {
      "if": {
        "properties": { "event_type": { "const": "authority.epoch.rotated" } },
        "required": ["event_type"]
      },
      "then": {
        "properties": {
          "authorization_ref": { "type": "null" },
          "body_id": { "type": "null" },
          "transfer_id": { "type": "null" },
          "signature": { "type": "object", "properties": { "signer_type": { "const": "guardian" } } }
        }
      }
    }
  ]
}
