{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:genesis:schema:recovery-authorization:v0.1",
  "title": "Genesis Policy-Bound Recovery Authorization",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "authorization_id",
    "recovery_id",
    "instance_id",
    "recovery_policy_id",
    "recovery_policy_digest",
    "policy_epoch",
    "authorization_path",
    "source_backup_id",
    "source_backup_commit_digest",
    "previous_body_id",
    "new_body_id",
    "reason",
    "issued_at",
    "not_before",
    "expires_at",
    "authorization_digest",
    "approvals"
  ],
  "properties": {
    "schema_version": { "const": "genesis.recovery.authorization.v0.1" },
    "authorization_id": { "type": "string", "minLength": 16, "maxLength": 128 },
    "recovery_id": { "type": "string", "minLength": 16, "maxLength": 128 },
    "instance_id": { "type": "string", "minLength": 16, "maxLength": 128 },
    "recovery_policy_id": { "type": "string", "minLength": 16, "maxLength": 128 },
    "recovery_policy_digest": { "$ref": "#/$defs/sha256" },
    "policy_epoch": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
    "authorization_path": { "type": "string", "enum": ["guardian_assisted", "policy_fallback"] },
    "source_backup_id": { "type": "string", "minLength": 16, "maxLength": 128 },
    "source_backup_commit_digest": { "$ref": "#/$defs/sha256" },
    "previous_body_id": { "type": "string", "minLength": 16, "maxLength": 128 },
    "new_body_id": { "type": "string", "minLength": 16, "maxLength": 128 },
    "reason": { "type": "string", "enum": ["lost", "destroyed", "damaged", "compromised", "inaccessible"] },
    "issued_at": { "$ref": "#/$defs/timestamp" },
    "not_before": { "$ref": "#/$defs/timestamp" },
    "expires_at": { "$ref": "#/$defs/timestamp" },
    "authorization_digest": { "$ref": "#/$defs/sha256" },
    "approvals": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "items": { "$ref": "urn:genesis:schema:signature-envelope:v0.1" }
    }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])-(0[1-9]|[12][0-9]|3[01])T([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]Z$"
    }
  }
}
