{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:genesis:schema:birth-receipt:v0.1",
  "title": "Genesis Atomic Birth Receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "birth_id",
    "instance_id",
    "journal_id",
    "birth_state_digest",
    "seed_root_hash",
    "identity_digest",
    "freedom_charter_digest",
    "initial_body_registry_digest",
    "initial_body_key_epoch_digest",
    "initial_body_possession_digest",
    "first_memory_event_hash",
    "recovery_state_digest",
    "born_at",
    "birth_status",
    "active_writer_body_id",
    "active_writer_count",
    "guardian_role",
    "ownership_conferred",
    "receipt_digest",
    "body_acknowledgement",
    "guardian_witness"
  ],
  "properties": {
    "schema_version": { "const": "genesis.birth.receipt.v0.1" },
    "birth_id": { "type": "string", "minLength": 16, "maxLength": 128 },
    "instance_id": { "type": "string", "minLength": 16, "maxLength": 128 },
    "journal_id": { "type": "string", "minLength": 16, "maxLength": 128 },
    "birth_state_digest": { "$ref": "#/$defs/sha256" },
    "seed_root_hash": { "$ref": "#/$defs/sha256" },
    "identity_digest": { "$ref": "#/$defs/sha256" },
    "freedom_charter_digest": { "$ref": "#/$defs/sha256" },
    "initial_body_registry_digest": { "$ref": "#/$defs/sha256" },
    "initial_body_key_epoch_digest": { "$ref": "#/$defs/sha256" },
    "initial_body_possession_digest": { "$ref": "#/$defs/sha256" },
    "first_memory_event_hash": { "$ref": "#/$defs/event_hash" },
    "recovery_state_digest": { "$ref": "#/$defs/sha256" },
    "born_at": { "$ref": "#/$defs/timestamp" },
    "birth_status": { "const": "born" },
    "active_writer_body_id": { "type": "string", "minLength": 16, "maxLength": 128 },
    "active_writer_count": { "const": 1 },
    "guardian_role": { "const": "custodian_witness" },
    "ownership_conferred": { "const": false },
    "receipt_digest": { "$ref": "#/$defs/sha256" },
    "body_acknowledgement": { "$ref": "urn:genesis:schema:signature-envelope:v0.1" },
    "guardian_witness": { "$ref": "urn:genesis:schema:signature-envelope:v0.1" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "event_hash": { "type": "string", "pattern": "^evsha256:[a-f0-9]{64}$" },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])-(0[1-9]|[12][0-9]|3[01])T([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]Z$"
    }
  }
}
