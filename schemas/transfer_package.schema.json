{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:genesis:schema:transfer-package:v0.1",
  "title": "Genesis Transfer Package",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "transfer_id",
    "instance_id",
    "source_body_id",
    "mode",
    "created_at",
    "checkpoint_hash",
    "last_event_hash",
    "contents",
    "package_digest",
    "authorization_ref",
    "continuity_status"
  ],
  "properties": {
    "schema_version": { "const": "genesis.transfer.package.v0.1" },
    "transfer_id": { "type": "string", "minLength": 16, "maxLength": 128 },
    "instance_id": { "type": "string", "minLength": 16, "maxLength": 128 },
    "source_body_id": { "type": "string", "minLength": 16, "maxLength": 128 },
    "destination_body_id": { "type": ["string", "null"], "minLength": 16, "maxLength": 128 },
    "mode": { "type": "string", "enum": ["transfer", "recovery"] },
    "created_at": { "type": "string", "format": "date-time", "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])-(0[1-9]|[12][0-9]|3[01])T([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]Z$" },
    "checkpoint_hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "last_event_hash": { "type": "string", "pattern": "^evsha256:[a-f0-9]{64}$" },
    "contents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "path", "digest"],
        "properties": {
          "kind": { "type": "string", "minLength": 1, "maxLength": 128 },
          "path": { "type": "string", "minLength": 1, "maxLength": 1024 },
          "digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
        }
      }
    },
    "package_digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "authorization_ref": { "type": "string", "minLength": 1, "maxLength": 256 },
    "continuity_status": {
      "type": "string",
      "enum": ["complete", "known_gap", "fork_risk"]
    }
  }
}
