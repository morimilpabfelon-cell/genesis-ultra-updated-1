{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:genesis:schema:instance-identity:v0.1",
  "title": "Genesis Instance Identity",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "instance_id", "seed_id", "seed_root_hash", "companion_name", "guardian_id", "born_at", "identity_digest"],
  "properties": {
    "schema_version": {"const": "genesis.instance.identity.v0.1"},
    "instance_id": {"type": "string", "minLength": 16},
    "seed_id": {"type": "string", "minLength": 16},
    "seed_root_hash": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "companion_name": {"type": "string", "minLength": 1, "maxLength": 128},
    "guardian_id": {"type": "string", "minLength": 1},
    "born_at": {"type": "string", "format": "date-time", "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])-(0[1-9]|[12][0-9]|3[01])T([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]Z$"},
    "identity_digest": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"}
  }
}
