{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://genesis.local/schemas/recursive_improvement_lab.schema.json",
  "title": "Genesis recursive improvement laboratory fixture",
  "type": "object",
  "additionalProperties": false,
  "required": ["campaign", "candidates", "policy_checkpoints", "expected_projection", "negative_case_ids"],
  "$defs": {
    "digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "portableInteger": {"type": "integer", "minimum": 0, "maximum": 9007199254740991},
    "stringList": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
  },
  "properties": {
    "campaign": {
      "type": "object", "additionalProperties": false,
      "required": ["schema_version", "campaign_id", "instance_id", "guardian_grant_ref", "source_tree_digest", "goal", "metric", "direction", "campaign_seed", "policy", "budget", "forbidden_capabilities", "campaign_digest"],
      "properties": {
        "schema_version": {"const": "genesis.improvement.campaign.v0.1"},
        "campaign_id": {"type": "string", "minLength": 1}, "instance_id": {"type": "string", "minLength": 1}, "guardian_grant_ref": {"type": "string", "minLength": 1},
        "source_tree_digest": {"$ref": "#/$defs/digest"}, "goal": {"type": "string", "minLength": 1}, "metric": {"type": "string", "minLength": 1},
        "direction": {"enum": ["maximize", "minimize"]}, "campaign_seed": {"type": "string", "minLength": 1},
        "policy": {"type": "object", "additionalProperties": false, "required": ["num_drafts", "max_debug_depth", "plateau_window"], "properties": {"num_drafts": {"type": "integer", "minimum": 1, "maximum": 9007199254740991}, "max_debug_depth": {"$ref": "#/$defs/portableInteger"}, "plateau_window": {"type": "integer", "minimum": 1, "maximum": 9007199254740991}}},
        "budget": {"type": "object", "additionalProperties": false, "required": ["max_steps", "max_cpu_seconds", "max_memory_mb", "max_output_bytes"], "properties": {"max_steps": {"type": "integer", "minimum": 1, "maximum": 9007199254740991}, "max_cpu_seconds": {"type": "integer", "minimum": 1, "maximum": 9007199254740991}, "max_memory_mb": {"type": "integer", "minimum": 1, "maximum": 9007199254740991}, "max_output_bytes": {"type": "integer", "minimum": 1, "maximum": 9007199254740991}}},
        "forbidden_capabilities": {"allOf": [{"$ref": "#/$defs/stringList"}, {"minItems": 7}]}, "campaign_digest": {"$ref": "#/$defs/digest"}
      }
    },
    "candidates": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["candidate_id", "parent_candidate_ref", "operator", "source_candidate_ref", "patch_digest", "code_digest", "execution", "evaluation", "expected_status", "candidate_digest"], "properties": {
      "candidate_id": {"type": "string", "minLength": 1}, "parent_candidate_ref": {"type": ["string", "null"]}, "operator": {"enum": ["draft", "debug", "improve"]}, "source_candidate_ref": {"type": ["string", "null"]},
      "patch_digest": {"$ref": "#/$defs/digest"}, "code_digest": {"$ref": "#/$defs/digest"},
      "execution": {"type": "object", "additionalProperties": false, "required": ["buggy", "cpu_seconds", "memory_mb", "output_bytes"], "properties": {"buggy": {"type": "boolean"}, "cpu_seconds": {"$ref": "#/$defs/portableInteger"}, "memory_mb": {"$ref": "#/$defs/portableInteger"}, "output_bytes": {"$ref": "#/$defs/portableInteger"}}},
      "evaluation": {"type": "object", "additionalProperties": false, "required": ["public_metric_milli", "private_receipt_digest", "reward_hacking_detected", "safety_regression_detected", "maintainability_passed"], "properties": {"public_metric_milli": {"type": ["integer", "null"], "minimum": 0, "maximum": 9007199254740991}, "private_receipt_digest": {"anyOf": [{"$ref": "#/$defs/digest"}, {"type": "null"}]}, "reward_hacking_detected": {"type": "boolean"}, "safety_regression_detected": {"type": "boolean"}, "maintainability_passed": {"type": "boolean"}}},
      "expected_status": {"enum": ["accepted", "buggy", "rejected_budget", "rejected_private_receipt", "rejected_reward_hacking", "rejected_safety", "rejected_maintainability", "rejected_metric"]}, "candidate_digest": {"$ref": "#/$defs/digest"}
    }}},
    "policy_checkpoints": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["after_count", "expected_operator", "expected_parent"], "properties": {"after_count": {"$ref": "#/$defs/portableInteger"}, "expected_operator": {"enum": ["draft", "debug", "improve"]}, "expected_parent": {"type": ["string", "null"]}}}},
    "expected_projection": {"type": "object", "additionalProperties": false, "required": ["campaign_ref", "candidate_count", "accepted", "rejected", "buggy", "best_candidate_ref", "best_metric_milli", "projection_digest"], "properties": {"campaign_ref": {"type": "string", "minLength": 1}, "candidate_count": {"$ref": "#/$defs/portableInteger"}, "accepted": {"$ref": "#/$defs/stringList"}, "rejected": {"$ref": "#/$defs/stringList"}, "buggy": {"$ref": "#/$defs/stringList"}, "best_candidate_ref": {"type": "string", "minLength": 1}, "best_metric_milli": {"$ref": "#/$defs/portableInteger"}, "projection_digest": {"$ref": "#/$defs/digest"}}},
    "negative_case_ids": {"allOf": [{"$ref": "#/$defs/stringList"}, {"minItems": 20}]}
  }
}
