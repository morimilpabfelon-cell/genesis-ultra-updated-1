{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://genesis.local/schemas/recursive_improvement_lab.schema.json",
  "title": "Genesis recursive improvement laboratory fixture",
  "type": "object",
  "additionalProperties": false,
  "required": ["campaign", "candidates", "policy_checkpoints", "expected_projection", "negative_case_ids"],
  "properties": {
    "campaign": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "campaign_id", "instance_id", "guardian_grant_ref", "source_tree_digest", "goal", "metric", "direction", "campaign_seed", "policy", "budget", "forbidden_capabilities", "campaign_digest"],
      "properties": {
        "schema_version": {"const": "genesis.improvement.campaign.v0.1"},
        "campaign_id": {"type": "string", "minLength": 1},
        "instance_id": {"type": "string", "minLength": 1},
        "guardian_grant_ref": {"type": "string", "minLength": 1},
        "source_tree_digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
        "goal": {"type": "string", "minLength": 1},
        "metric": {"type": "string", "minLength": 1},
        "direction": {"enum": ["maximize", "minimize"]},
        "campaign_seed": {"type": "string", "minLength": 1},
        "policy": {"type": "object", "additionalProperties": false, "required": ["num_drafts", "max_debug_depth", "plateau_window"], "properties": {"num_drafts": {"type": "integer", "minimum": 1, "maximum": 9007199254740991}, "max_debug_depth": {"type": "integer", "minimum": 0, "maximum": 9007199254740991}, "plateau_window": {"type": "integer", "minimum": 1, "maximum": 9007199254740991}}},
        "budget": {"type": "object", "additionalProperties": false, "required": ["max_steps", "max_cpu_seconds", "max_memory_mb", "max_output_bytes"], "properties": {"max_steps": {"type": "integer", "minimum": 1, "maximum": 9007199254740991}, "max_cpu_seconds": {"type": "integer", "minimum": 1, "maximum": 9007199254740991}, "max_memory_mb": {"type": "integer", "minimum": 1, "maximum": 9007199254740991}, "max_output_bytes": {"type": "integer", "minimum": 1, "maximum": 9007199254740991}}},
        "forbidden_capabilities": {"type": "array", "minItems": 7, "uniqueItems": true, "items": {"type": "string"}},
        "campaign_digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}
      }
    },
    "candidates": {"type": "array", "minItems": 1, "items": {"type": "object", "required": ["candidate_id", "parent_candidate_ref", "operator", "source_candidate_ref", "patch_digest", "code_digest", "execution", "evaluation", "expected_status", "candidate_digest"]}},
    "policy_checkpoints": {"type": "array", "minItems": 1},
    "expected_projection": {"type": "object", "required": ["campaign_ref", "candidate_count", "accepted", "rejected", "buggy", "best_candidate_ref", "best_metric_milli", "projection_digest"]},
    "negative_case_ids": {"type": "array", "minItems": 20, "uniqueItems": true, "items": {"type": "string"}}
  }
}
