{
  "name": "genesis-ultra-workspace",
  "version": "0.1.0-draft",
  "private": true,
  "type": "module",
  "description": "Neutral Genesis protocol workspace. Tooling is non-normative.",
  "scripts": {
    "validate": "node tools/run_conformance.mjs",
    "test": "node tools/run_conformance.mjs",
    "observe": "node observer/server.mjs",
    "test:observer": "node --test observer/test/core.test.mjs",
    "validate:node": "node tools/validate_workspace.mjs",
    "validate:host": "node tools/validate_host_adapter.mjs",
    "validate:identity": "node tools/validate_instance_identity.mjs",
    "validate:senses": "node tools/validate_sense_observations.mjs",
    "validate:sense-adapters": "node tools/validate_sense_adapters.mjs",
    "validate:retrieval": "node tools/validate_memory_retrieval.mjs",
    "validate:retrieval-bridge": "node tools/memory_gate_retrieval_bridge.mjs validate",
    "validate:hybrid-retrieval": "node tools/hybrid_memory_retrieval.mjs validate",
    "validate:retrieval-acl": "node tools/memory_retrieval_acl.mjs validate",
    "memory:build": "node tools/memory_retrieval.mjs build",
    "memory:query": "node tools/memory_retrieval.mjs query",
    "memory:bridge:build": "node tools/memory_gate_retrieval_bridge.mjs build",
    "memory:bridge:sync": "node tools/memory_gate_retrieval_bridge.mjs sync",
    "memory:bridge:query": "node tools/memory_gate_retrieval_bridge.mjs query",
    "memory:hybrid:build": "node tools/hybrid_memory_retrieval.mjs build",
    "memory:hybrid:sync": "node tools/hybrid_memory_retrieval.mjs sync",
    "memory:hybrid:query": "node tools/hybrid_memory_retrieval.mjs query",
    "memory:acl:filter": "node tools/memory_retrieval_acl.mjs filter",
    "validate:vectors": "node tools/validate_protocol_vectors.mjs",
    "validate:schemas": "node tools/validate_artifacts.mjs"
  },
  "devDependencies": {
    "ajv": "8.17.1",
    "ajv-formats": "3.0.1",
    "hash-wasm": "4.12.0"
  },
  "engines": {
    "node": ">=20"
  }
}
