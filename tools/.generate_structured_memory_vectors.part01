        "valid_to": valid_to,
        "extractor_profile": "genesis.memory.structured.fixture-extractor.v0.1",
        "extractor_digest": EXTRACTOR_DIGEST,
        "confidence_milli": 1000,
        "asserted_at": source["observed_at"],
        "privacy": source["privacy"],
        "scope": scope,
        "assertion_digest": "",
    }
    item["assertion_digest"] = compute_assertion_digest(item)
    return item

