def mutation(case_id, action, path=None, value=None, expected_error=None, indices=None):
    item = {"case_id": case_id, "mutation": {"action": action}, "expected_error": expected_error}
    if path is not None:
        item["mutation"]["path"] = path
    if value is not None:
        item["mutation"]["value"] = value
    if indices is not None:
        item["mutation"]["indices"] = indices
    return item
