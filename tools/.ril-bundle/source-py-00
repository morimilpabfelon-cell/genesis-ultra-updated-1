    if not accepted:
        return None
    direction = "maximize"
    if direction == "maximize":
        return sorted(accepted, key=lambda item: (-item["evaluation"]["public_score_milli"], item["sequence"], item["candidate_id"].encode("utf-8")))[0]
    return sorted(accepted, key=lambda item: (item["evaluation"]["public_score_milli"], item["sequence"], item["candidate_id"].encode("utf-8")))[0]


