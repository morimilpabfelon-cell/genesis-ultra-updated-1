"grants"][0],
        ),
        (
            "guided-autonomy-projection-rejects-unexpected-field",
            "guided_autonomy_projection.schema.json",
            projection,
        ),
    ]
    for case_id, schema, artifact in artifacts:
        candidate = json.loads(json.dumps(artifact))
        candidate["unexpected_core_field"] = True
        cases.append(
            {
                "case_id": case_id,
                "schema": schema,
                "expected_error_keyword": "additionalProperties",
                "artifact": candidate,
            }
        )
    cases_doc["cases"] = cases
    write_json("conformance/schema_invalid_cases.json", cases_doc)


def update_observer() -> None:
    system_map = load_json("observer/system-map.json")
    component = {
        "id": "guided_autonomy",
        "name": "Autonomía guiada",
        "layer": "cognition",
        "maturity": "verified",
        "description": "Propuestas, evaluación, grants firmados, niveles de autonomía, suspensión y revocación bajo autoridad exclusiva del guardián.",
        "keywords": [
            "guided_autonomy",
            "capability_grant",
            "capability_authority_event",
            "autonomy_level",
        ],
        "required_evidence": ["spec", "schema", "conformance", "implementation"],
    }
    components = [item for item in system_map["components"] if item["id"] != "guided_autonomy"]
    action_index = next(
        (index for index, item in enumerate(components) if item["id"] == "action"), len(components)
    )
    components.insert(action_index, component)
    system_map["components"] = components
    flow = [item for item in system_map["flow"] if item != "guided_autonomy"]
    action_index = flow.index("action") if "action" in flow else len(flow)
    flow.insert(action_index, "guided_autonomy")
    system_map["flow"] = flow
    write_json("observer/system-map.json", system_map)


