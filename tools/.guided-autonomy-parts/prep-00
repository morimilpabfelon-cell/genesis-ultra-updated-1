GENERATOR = ROOT / ".tmp_generate_guided_autonomy_fixture.py"
TEMP_PROJECTION = ROOT / ".tmp_guided_autonomy_projection.json"

PRODUCT_FILES = [
    "conformance/guided_autonomy_vectors.json",
    "schemas/capability_authority_event.schema.json",
    "schemas/capability_grant.schema.json",
