ROOT = Path(__file__).resolve().parents[1]
TOOLS_PARTS = ROOT / "tools" / ".guided-autonomy-parts"
VECTOR_PARTS = ROOT / "conformance" / ".guided-autonomy-parts"
WORKFLOW = ROOT / ".github" / "workflows" / "finalize-guided-autonomy.yml"
